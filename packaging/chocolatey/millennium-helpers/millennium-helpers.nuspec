<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>millennium-helpers</id>
    <version>2.7.0</version>
    <title>Millennium Helpers</title>
    <authors>bolens</authors>
    <projectUrl>https://github.com/bolens/millenium-helpers</projectUrl>
    <licenseUrl>https://github.com/bolens/millenium-helpers/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>
      Millennium helpers for Windows (release zip / bin). Installs PowerShell helpers
      and millennium.exe when present in the archive. Chocolatey ships the bin variant
      only (no from-source build); tip-of-main is via Scoop/Winget git packages.
    </description>
    <summary>Cross-platform Millennium helper CLI (Windows release assets)</summary>
    <tags>millennium steam helpers cli</tags>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
