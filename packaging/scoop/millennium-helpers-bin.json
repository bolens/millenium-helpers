{
    "version": "3.0.1",
    "description": "Millennium helpers (prebuilt release zip) \u2014 Go CLI (millennium.exe) for Millennium Steam mods.",
    "homepage": "https://github.com/bolens/millenium-helpers",
    "license": "MIT",
    "url": "https://github.com/bolens/millenium-helpers/releases/download/v3.0.1/millennium-helpers-v3.0.1-windows-amd64.zip",
    "hash": "9bf4dc9e48be808a8a38478d10979e09e59b69a1a309452f7ee2093451782a97",
    "bin": [
        [
            "scripts\\windows\\millennium.exe",
            "millennium"
        ]
    ],
    "post_install": [
        "$compSrc = Join-Path $dir 'completions\\powershell\\millennium-helpers.ps1'",
        "if (Test-Path $compSrc) {",
        "  $hook = '. \"' + $compSrc + '\"'",
        "  $profiles = @(",
        "    (Join-Path $env:USERPROFILE 'Documents\\PowerShell\\Microsoft.PowerShell_profile.ps1'),",
        "    (Join-Path $env:USERPROFILE 'Documents\\WindowsPowerShell\\Microsoft.PowerShell_profile.ps1')",
        "  )",
        "  foreach ($p in $profiles) {",
        "    $parent = Split-Path $p -Parent",
        "    if (!(Test-Path $parent)) { New-Item -ItemType Directory -Path $parent -Force | Out-Null }",
        "    $existing = if (Test-Path $p) { Get-Content $p -Raw } else { '' }",
        "    if ($existing -notlike '*millennium-helpers.ps1*') {",
        "      Add-Content -Path $p -Value \"`n# Millennium Helpers completions`n$hook`n\"",
        "      Write-Host \"Registered PowerShell completions in $p\"",
        "    }",
        "  }",
        "} else {",
        "  Write-Host 'PowerShell completion script not found in package; skipping profile hooks.'",
        "}"
    ],
    "pre_uninstall": [
        "try { Unregister-ScheduledTask -TaskName 'MillenniumUpdate' -Confirm:$false -ErrorAction SilentlyContinue } catch {}",
        "$profiles = @(",
        "  (Join-Path $env:USERPROFILE 'Documents\\PowerShell\\Microsoft.PowerShell_profile.ps1'),",
        "  (Join-Path $env:USERPROFILE 'Documents\\WindowsPowerShell\\Microsoft.PowerShell_profile.ps1')",
        ")",
        "foreach ($p in $profiles) {",
        "  if (!(Test-Path $p)) { continue }",
        "  $content = Get-Content $p -Raw -ErrorAction SilentlyContinue",
        "  if ($content -and ($content -like '*millennium-helpers.ps1*' -or $content -like '*millennium-helpers.completion.ps1*')) {",
        "    $filtered = ($content -split \"`n\" | Where-Object {",
        "      $_ -notmatch 'millennium-helpers(\\.completion)?\\.ps1' -and",
        "      $_ -notmatch '^\\s*# Millennium Helpers completions\\s*$'",
        "    }) -join \"`n\"",
        "    Set-Content -Path $p -Value $filtered -Encoding UTF8",
        "  }",
        "}"
    ],
    "autoupdate": {
        "url": "https://github.com/bolens/millenium-helpers/releases/download/v$version/millennium-helpers-v$version-windows-amd64.zip",
        "hash": {
            "url": "https://github.com/bolens/millenium-helpers/releases/download/v$version/millennium-helpers-v$version-windows-amd64.zip.sha256"
        }
    }
}
