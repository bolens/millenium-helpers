# Maintainer: bolens <https://github.com/bolens>
pkgname=millennium-helpers-git
_pkgname=millennium-helpers
pkgver=r245.gbc5c197
pkgrel=1
pkgdesc="Millennium helpers (git tip) — Go strangler CLI plus shell helpers/MCP"
arch=('x86_64' 'aarch64')
url="https://github.com/bolens/millenium-helpers"
license=('MIT')
depends=('bash' 'curl' 'unzip' 'python' 'sudo')
makedepends=('git' 'go')
optdepends=(
  'jq: enhanced JSON parsing for updates'
  'systemd: daily update timer scheduler'
  'libnotify: desktop notifications for background update status'
  'flatpak: compatibility with Flatpak Steam'
  'cronie: alternative daily update timer scheduler via cron (fallback)'
)
provides=("${_pkgname}")
conflicts=("${_pkgname}" "${_pkgname}-bin")
install=millennium-helpers.install
backup=('etc/sudoers.d/millennium-helpers')
source=("${_pkgname}::git+${url}.git"
        "millennium-helpers.sudoers")
sha256sums=('SKIP'
            'b242d171bced3313da83fb6bfd6b29fdaf17fec28892b6e38435d7dd321949bd')

prepare() {
  # shellcheck source=/dev/null
  source "${startdir}/arch-unix-install.sh"
  _arch_prepare_manual_conflict_check
}

pkgver() {
  cd "${srcdir}/${_pkgname}"
  printf "r%s.g%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  cd "${srcdir}/${_pkgname}"
  export CGO_ENABLED=0
  make build
}

package() {
  # shellcheck source=/dev/null
  source "${startdir}/arch-unix-install.sh"
  install -Dm440 "${srcdir}/millennium-helpers.sudoers" "${pkgdir}/etc/sudoers.d/millennium-helpers"
  cd "${srcdir}/${_pkgname}"
  _arch_install_unix_helpers
}
