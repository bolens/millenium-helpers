# Enable passwordless Millennium client maintenance for members of the wheel group.
# Allows Go dispatcher verbs (upgrade/diag/repair/purge). Shipped with the
# millennium-helpers Arch package.
%wheel ALL=(ALL) NOPASSWD: /usr/bin/millennium upgrade, /usr/bin/millennium upgrade *, /usr/bin/millennium diag, /usr/bin/millennium diag *, /usr/bin/millennium repair, /usr/bin/millennium repair *, /usr/bin/millennium purge, /usr/bin/millennium purge *
