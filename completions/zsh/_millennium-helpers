#compdef millennium-repair millennium-upgrade millennium-schedule millennium-purge millennium-diag millennium-theme millennium-mcp

_millennium_helpers() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  case "$service" in
    millennium-repair)
      _arguments \
        {-d,--dry-run}'[Simulation mode]' \
        {-h,--help}'[Show help message]'
      ;;
    millennium-upgrade)
      _arguments \
        '--channel[Update channel (stable or beta)]' \
        '--stable[Alias for --channel stable]' \
        '--beta[Alias for --channel beta]' \
        '--rollback[Rollback to a specific version or list backups]' \
        {-f,--force}'[Force reinstall]' \
        {-d,--dry-run}'[Simulation mode]' \
        {-h,--help}'[Show help message]'
      ;;
    millennium-schedule)
      _arguments \
        '1:subcommand:(enable disable status)' \
        '2:channel:(stable beta)' \
        {-h,--help}'[Show help message]'
      ;;
    millennium-purge)
      _arguments \
        {-d,--dry-run}'[Simulation mode]' \
        {-h,--help}'[Show help message]'
      ;;
    millennium-diag)
      _arguments \
        '1:subcommand:(doctor --fix)' \
        '--force[Force all doctor repairs even if system is healthy]' \
        '--json[Output diagnostics report in structured JSON format]' \
        {-d,--dry-run}'[Simulation mode]' \
        {-h,--help}'[Show help message]'
      ;;
    millennium-theme)
      _arguments \
        '1:subcommand:(list install remove update)' \
        '2:theme:_files' \
        '--all[Update all themes]' \
        '--json[Output list command results in structured JSON format]' \
        {-d,--dry-run}'[Simulation mode]' \
        {-h,--help}'[Show help message]'
      ;;
    millennium-mcp)
      _arguments \
        {-h,--help}'[Show help message]'
      ;;
  esac
}

_millennium_helpers "$@"
