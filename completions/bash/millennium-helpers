_millennium_diag_comp() {
  COMPREPLY=()
  local cur="${COMP_WORDS[COMP_CWORD]}"
  # @@cli-contract:commands.diag.subcommands@@
  local subcmds="doctor logs"
  # @@/cli-contract:commands.diag.subcommands@@
  # @@cli-contract:commands.diag.flags@@
  local flagopts="-f --fix --force --json -l --follow -s --share -y --yes -d --dry-run -q --quiet -V --version -h --help"
  # @@/cli-contract:commands.diag.flags@@
  COMPREPLY=( $(compgen -W "${subcmds} ${flagopts}" -- "${cur}") )
