_millennium_theme_comp() {
  COMPREPLY=()
  local cur="${COMP_WORDS[COMP_CWORD]}"
  local prev="${COMP_WORDS[COMP_CWORD-1]}"
  # @@cli-contract:commands.theme.subcommands@@
  local subcmds="list install update remove"
  # @@/cli-contract:commands.theme.subcommands@@
  # @@cli-contract:commands.theme.flags@@
  local flagopts="-a --all --json -y --yes -d --dry-run -q --quiet -V --version -h --help"
  # @@/cli-contract:commands.theme.flags@@

  case "${prev}" in
    update)
      COMPREPLY=( $(compgen -W "--all -a $(_millennium_theme_names)" -- "${cur}") )
      return 0
      ;;
    list)
      COMPREPLY=( $(compgen -W "--json -d --dry-run -h --help" -- "${cur}") )
      return 0
      ;;
    remove)
      COMPREPLY=( $(compgen -W "$(_millennium_theme_names)" -- "${cur}") )
      return 0
      ;;
    install)
      COMPREPLY=()
      return 0
      ;;
  esac

  COMPREPLY=( $(compgen -W "${subcmds} ${flagopts}" -- "${cur}") )
  return 0
}

_millennium_mcp_comp() {
  COMPREPLY=()
  local cur="${COMP_WORDS[COMP_CWORD]}"
  # @@cli-contract:commands.mcp.flags@@
  local flagopts="-r --register -V --version -h --help"
  # @@/cli-contract:commands.mcp.flags@@
  COMPREPLY=( $(compgen -W "${flagopts}" -- "${cur}") )
  return 0
}

_millennium_install_comp() {
  COMPREPLY=()
  local cur="${COMP_WORDS[COMP_CWORD]}"
  # @@cli-contract:commands.install_uninstall.flags@@
  local flagopts="--track --tag --allow-unsigned-main --prefix --target-dir --lib-dir --source-root --skip-wizard -d --dry-run -f --force -V --version -h --help -p --purge"
  # @@/cli-contract:commands.install_uninstall.flags@@
  COMPREPLY=( $(compgen -W "${flagopts}" -- "${cur}") )
  return 0
}

_millennium_dispatcher_comp() {
  COMPREPLY=()
  local cur="${COMP_WORDS[COMP_CWORD]}"
  if [[ ${COMP_CWORD} -eq 1 ]]; then
    # @@cli-contract:dispatcher.commands@@
    COMPREPLY=( $(compgen -W "diag doctor upgrade schedule theme repair purge mcp install uninstall help" -- "${cur}") )
    # @@/cli-contract:dispatcher.commands@@
    return 0
  fi
  local sub="${COMP_WORDS[1]}"
  case "$sub" in
    diag|doctor) _millennium_diag_comp ;;
    upgrade) _millennium_upgrade_comp ;;
    schedule) _millennium_schedule_comp ;;
    theme) _millennium_theme_comp ;;
    repair) _millennium_repair_comp ;;
    purge) _millennium_purge_comp ;;
    mcp) _millennium_mcp_comp ;;
    install|uninstall) _millennium_install_comp ;;
  esac
}
complete -F _millennium_dispatcher_comp millennium
