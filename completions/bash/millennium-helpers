# Bash completions for Millennium helper scripts

_millennium_repair_comp() {
  COMPREPLY=()
  local cur="${COMP_WORDS[COMP_CWORD]}"
  local opts="-s --skip-theme -d --dry-run -V --version -h --help"
  COMPREPLY=( $(compgen -W "${opts}" -- "${cur}") )
  return 0
}
complete -F _millennium_repair_comp millennium-repair

_millennium_upgrade_comp() {
  COMPREPLY=()
  local cur="${COMP_WORDS[COMP_CWORD]}"
  local opts="-c --channel --stable --beta -r --rollback --file -f --force -d --dry-run -V --version -h --help"
  COMPREPLY=( $(compgen -W "${opts}" -- "${cur}") )
  return 0
}
complete -F _millennium_upgrade_comp millennium-upgrade

_millennium_schedule_comp() {
  COMPREPLY=()
  local cur="${COMP_WORDS[COMP_CWORD]}"
  local prev="${COMP_WORDS[COMP_CWORD-1]}"
  local subcmds="enable disable status setup config"
  
  case "${prev}" in
    enable)
      COMPREPLY=( $(compgen -W "stable beta" -- "${cur}") )
      return 0
      ;;
    config)
      COMPREPLY=( $(compgen -W "get set list" -- "${cur}") )
      return 0
      ;;
    disable|status|setup)
      COMPREPLY=()
      return 0
      ;;
  esac
  
  COMPREPLY=( $(compgen -W "${subcmds} -d --dry-run -V --version -h --help" -- "${cur}") )
  return 0
}
complete -F _millennium_schedule_comp millennium-schedule

