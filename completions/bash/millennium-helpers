_millennium_theme_comp() {
  COMPREPLY=()
  local cur="${COMP_WORDS[COMP_CWORD]}"
  local prev="${COMP_WORDS[COMP_CWORD-1]}"
  local subcmds="list install remove update"
  
  case "${prev}" in
    update)
      COMPREPLY=( $(compgen -W "--all -a" -- "${cur}") )
      return 0
      ;;
    list)
      COMPREPLY=( $(compgen -W "--json -d --dry-run -h --help" -- "${cur}") )
      return 0
      ;;
    install|remove)
      COMPREPLY=()
      return 0
      ;;
  esac
  
  COMPREPLY=( $(compgen -W "${subcmds} --json -d --dry-run -V --version -h --help" -- "${cur}") )
  return 0
}
complete -F _millennium_theme_comp millennium-theme

